# Database (PostgreSQL via Neon)
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/dashboard_kbg?sslmode=require"

# NextAuth
AUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Dashboard Pemantauan KBG & TPKS"

# Demo Mode (set to "true" to enable demo data)
NEXT_PUBLIC_DEMO_MODE="false"

# Encryption key for sensitive data (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="change-this-to-a-random-hex-string-32-bytes"
